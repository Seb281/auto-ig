# Google Gemini — AI for all agents + image generation (free tier)
GEMINI_API_KEY=

# Unsplash — stock photo search
UNSPLASH_ACCESS_KEY=

# Pexels — stock photo search (secondary)
PEXELS_API_KEY=

# Instagram — Meta Graph API access token (per-account, env var name set in config.yaml)
VEGGIE_IG_TOKEN=

# Discord — bot token and channel ID (per-account, env var names set in config.yaml)
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# VM public IP — required for Meta Graph API to fetch images from temp HTTP server
PUBLIC_IP=

# --- Facebook Pages (optional — opt-in via platforms list in config.yaml) ---
# VEGGIE_FB_PAGE_TOKEN=

# --- Multi-account: add env vars for each additional account below ---

# Second account example (fitness_meals)
# FITNESS_IG_TOKEN=
# FITNESS_DISCORD_CHANNEL_ID=
# FITNESS_FB_PAGE_TOKEN=
