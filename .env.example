# Anthropic — Claude API for all agents
ANTHROPIC_API_KEY=

# OpenAI — DALL-E 3 image generation (fallback)
OPENAI_API_KEY=

# Unsplash — stock photo search
UNSPLASH_ACCESS_KEY=

# Pexels — stock photo search (secondary)
PEXELS_API_KEY=

# Instagram — Meta Graph API access token (per-account, env var name set in config.yaml)
VEGGIE_IG_TOKEN=

# Telegram — bot token and chat ID (per-account, env var names set in config.yaml)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# VM public IP — required for Meta Graph API to fetch images from temp HTTP server
PUBLIC_IP=

# --- Multi-account: add env vars for each additional account below ---

# Second account example (fitness_meals)
# FITNESS_IG_TOKEN=
# FITNESS_TELEGRAM_CHAT_ID=
